        table tr:nth-child(even) td {
            background-color: #f9f9f9;
        }

        /* Hacer tablas scrolleables en móvil */
        @media (max-width: 768px) {
            table {
                font-size: 11px;
            }

            table th,
            table td {
                padding: 6px 4px;
                min-width: 100px;
            }

            /* Alternativa: tabla apilada en móvil */
            .stacked-table {
                display: block;
            }

            .stacked-table thead {
                display: none;
            }

            .stacked-table tr {
                display: block;
                margin-bottom: 15px;
                border: 1px solid #ddd;
                border-radius: 5px;
                background: white;
            }

            .stacked-table td {
                display: block;
                text-align: right;
                border: none;
                border-bottom: 1px solid #eee;
                padding: 8px;
            }

            .stacked-table td:last-child {
                border-bottom: none;
