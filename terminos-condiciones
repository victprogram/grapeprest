<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Términos y Condiciones - GrapePrest</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
            line-height: 1.6;
            max-width: 900px;
            margin: 0 auto;
            padding: 15px;
            color: #333;
            background: #f5f5f5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        h1 {
            color: #F80145;
            border-bottom: 3px solid #F80145;
            padding-bottom: 10px;
            margin-bottom: 20px;
            font-size: clamp(22px, 6vw, 32px);
        }

        h2 {
            color: #478935;
            margin-top: 30px;
            margin-bottom: 15px;
            font-size: clamp(18px, 5vw, 24px);
        }

        h3 {
            color: #1976D2;
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: clamp(16px, 4vw, 20px);
        }

        h4 {
            color: #555;
            margin-top: 15px;
            margin-bottom: 8px;
            font-size: clamp(14px, 3.5vw, 16px);
        }

        p {
            margin-bottom: 12px;
            font-size: clamp(13px, 3.5vw, 15px);
        }

        .last-update {
            background: #f0f0f0;
            padding: 12px;
            border-radius: 5px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .critical {
            background: #ffebee;
            border-left: 4px solid #F80145;
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        .important {
            background: #fff3cd;
            border-left: 4px solid #FF9800;
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        .info {
            background: #e3f2fd;
            border-left: 4px solid #1976D2;
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        .success {
            background: #e8f5e9;
            border-left: 4px solid #478935;
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        .contact-box {
            background: #e8f5e9;
            padding: 20px;
            border-left: 4px solid #478935;
            margin-top: 20px;
            border-radius: 5px;
        }

        .legal {
            background: white;
            border: 2px solid #ddd;
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        /* Optimización de tablas para móvil */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
            font-size: clamp(11px, 3vw, 14px);
            display: block;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table th {
            background: #478935;
            color: white;
            padding: 10px 8px;
            text-align: left;
            white-space: nowrap;
        }

        table td {
            border: 1px solid #ddd;
            padding: 8px;
            background: white;
        }

        table tr:nth-child(even) td {
            background-color: #f9f9f9;
        }

        /* Tablas apiladas en móvil */
        @media (max-width: 768px) {
            table {
                font-size: 11px;
            }

            table th,
            table td {
                padding: 6px 4px;
                min-width: 100px;
            }

            /* Versión apilada para tablas complejas */
            .stacked-table {
                display: block;
            }

            .stacked-table thead {
                display: none;
            }

            .stacked-table tr {
                display: block;
                margin-bottom: 15px;
                border: 1px solid #ddd;
                border-radius: 5px;
                background: white;
            }

            .stacked-table td {
                display: block;
                text-align: right;
                border: none;
                border-bottom: 1px solid #eee;
                padding: 8px;
            }

            .stacked-table td:last-child {
                border-bottom: none;
            }

            .stacked-table td::before {
                content: attr(data-label);
                float: left;
                font-weight: bold;
                color: #478935;
            }
        }

        .pricing-box {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: 2px solid #478935;
            border-radius: 10px;
            padding: 15px;
            margin: 15px 0;
        }

        .pricing-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            margin: 10px 0;
            background: white;
            border-radius: 8px;
            border-left: 4px solid #F80145;
            flex-wrap: wrap;
            gap: 10px;
        }

        .pricing-item .plan-name {
            font-weight: bold;
            color: #333;
            font-size: clamp(14px, 3.5vw, 16px);
            flex: 1 1 auto;
        }

        .pricing-item .prices {
            text-align: right;
            flex: 0 1 auto;
        }

        .pricing-item .price-usd {
            font-size: clamp(18px, 5vw, 22px);
            font-weight: bold;
            color: #478935;
        }

        .pricing-item .price-period {
            font-size: clamp(10px, 2.5vw, 12px);
            color: #888;
            margin-top: 3px;
        }

        .savings-badge {
            background: #478935;
            color: white;
            padding: 3px 10px;
            border-radius: 15px;
            font-size: clamp(10px, 2.5vw, 11px);
            margin-left: 8px;
            display: inline-block;
            margin-top: 5px;
        }

        .red-text {
            color: #d32f2f;
        }

        .bold {
            font-weight: bold;
        }

        .official-email {
            background: #e3f2fd;
            padding: 5px 10px;
            border-radius: 3px;
            font-weight: bold;
            word-break: break-word;
            display: inline-block;
        }

        ul, ol {
            margin-left: 20px;
            margin-bottom: 15px;
        }

        ul li, ol li {
            margin-bottom: 8px;
            line-height: 1.5;
        }

        a {
            color: #1976D2;
            text-decoration: none;
            word-wrap: break-word;
        }

        a:active {
            opacity: 0.7;
        }

        @media (min-width: 769px) {
            a:hover {
                text-decoration: underline;
            }
        }

        hr {
            margin: 25px 0;
            border: none;
            border-top: 1px solid #ddd;
        }

        /* Optimización de contenido */
        .content-section {
            contain: layout style paint;
        }

        /* Estilos responsive adicionales */
        @media (max-width: 768px) {
            body {
                padding: 10px;
            }

            .critical,
            .important,
            .info,
            .success,
            .contact-box,
            .legal,
            .pricing-box {
                padding: 12px;
                margin: 12px 0;
            }

            h1 {
                margin-bottom: 15px;
            }

            h2 {
                margin-top: 25px;
                margin-bottom: 12px;
            }

            h3 {
                margin-top: 15px;
                margin-bottom: 8px;
            }

            ul, ol {
                margin-left: 15px;
            }

            .pricing-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .pricing-item .prices {
                text-align: left;
                width: 100%;
            }
        }

        /* Optimización para reducir motion */
        @media (prefers-reduced-motion: reduce) {
            * {
                animation: none !important;
                transition: none !important;
            }
        }

        /* Estilos de impresión */
        @media print {
            body {
                max-width: 100%;
                background: white;
            }

            .critical,
            .important,
            .info,
            .success,
            .legal {
                border: 1px solid #999;
                page-break-inside: avoid;
            }

            table {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
